<svg width="100%" viewBox="0 0 680 720" xmlns="http://www.w3.org/2000/svg" role="img" style="">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">SecureBank cloud-native architecture on AWS EKS</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Three-tier banking application architecture showing user flow from browser through AWS Load Balancer, NGINX Ingress Controller, to React frontend pods and Spring Boot backend pods running on EKS, connecting to AWS RDS MySQL database.</desc>
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  <mask id="imagine-text-gaps-1j6s72" maskUnits="userSpaceOnUse"><rect x="0" y="0" width="680" height="720" fill="white"/><rect x="306.6640625" y="31" width="67.9129638671875" height="22" fill="black" rx="2"/><rect x="291.71875" y="50.5" width="97.48587036132812" height="19" fill="black" rx="2"/><rect x="273.203125" y="116" width="133.83087158203125" height="22" fill="black" rx="2"/><rect x="274.703125" y="135.5" width="131.73977661132812" height="19" fill="black" rx="2"/><rect x="56" y="204" width="85.54592895507812" height="22" fill="black" rx="2"/><rect x="56" y="222.5" width="120.74186706542969" height="19" fill="black" rx="2"/><rect x="252.640625" y="261" width="175.95083618164062" height="22" fill="black" rx="2"/><rect x="280.2734375" y="280.5" width="120.27984619140625" height="19" fill="black" rx="2"/><rect x="195" y="310.5" width="14" height="19" fill="black" rx="2"/><rect x="473" y="310.5" width="41.06195068359375" height="19" fill="black" rx="2"/><rect x="152.0859375" y="369" width="97.06089782714844" height="22" fill="black" rx="2"/><rect x="137.3828125" y="390.5" width="125.97979736328125" height="19" fill="black" rx="2"/><rect x="150.671875" y="420.5" width="99.48583984375" height="19" fill="black" rx="2"/><rect x="135.3828125" y="440.5" width="130.27587890625" height="19" fill="black" rx="2"/><rect x="433.859375" y="369" width="93.5189208984375" height="22" fill="black" rx="2"/><rect x="412.3828125" y="390.5" width="134.9837646484375" height="19" fill="black" rx="2"/><rect x="430.671875" y="420.5" width="99.48583984375" height="19" fill="black" rx="2"/><rect x="413.90625" y="440.5" width="133.23388671875" height="19" fill="black" rx="2"/><rect x="495" y="505.5" width="102.19384765625" height="19" fill="black" rx="2"/><rect x="406.03125" y="574" width="147.429931640625" height="22" fill="black" rx="2"/><rect x="402.71875" y="595.5" width="156.10986328125" height="19" fill="black" rx="2"/><rect x="410.34375" y="613.5" width="139.1378173828125" height="19" fill="black" rx="2"/><rect x="90.546875" y="574" width="139.7659149169922" height="22" fill="black" rx="2"/><rect x="87.1796875" y="595.5" width="145.47381591796875" height="19" fill="black" rx="2"/><rect x="99.0234375" y="613.5" width="122.77783203125" height="19" fill="black" rx="2"/><rect x="195.6875" y="670.5" width="289.05145263671875" height="19" fill="black" rx="2"/></mask></defs>

